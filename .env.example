# ============================================================
# VaultBank - Variaveis de Ambiente
# NUNCA commitar o arquivo .env real no Git!
# ============================================================

# PostgreSQL
POSTGRES_PASSWORD=sua_senha_segura_aqui

# Redis
REDIS_PASSWORD=sua_senha_redis_aqui

# JWT - gerar com: openssl rand -base64 64
JWT_SECRET=seu_jwt_secret_256bits_aqui

# AES-256 para criptografia de dados sensiveis
# Gerar com: python3 -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
CRYPTO_SECRET_KEY=sua_chave_aes256_base64_aqui

# Em producao, usar HashiCorp Vault ou AWS Secrets Manager
# para gerenciar estes secrets de forma segura
